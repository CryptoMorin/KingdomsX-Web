---
interface Props {
  count?: number;
}

const { count = 4 } = Astro.props;
const items = Array.from({ length: count });
---
<div class="servers-skeleton row row-cols-1 row-cols-md-2 g-3" aria-hidden="true">
  {items.map(() => (
    <div class="col d-flex">
      <article class="server-card server-card-skeleton d-flex flex-column gap-3 w-100 h-100 p-3 overflow-hidden rounded-3">
        <div class="server-card-top d-flex align-items-center gap-3">
          <span class="server-skeleton server-skeleton-icon flex-shrink-0 rounded-2"></span>
          <span class="server-skeleton-stack d-grid gap-2 flex-grow-1 min-w-0">
            <span class="server-skeleton server-skeleton-line server-skeleton-title"></span>
            <span class="server-skeleton server-skeleton-line server-skeleton-short"></span>
          </span>
        </div>
        <span class="server-skeleton-stack d-grid gap-2">
          <span class="server-skeleton server-skeleton-line"></span>
          <span class="server-skeleton server-skeleton-line server-skeleton-short"></span>
        </span>
        <span class="server-skeleton-footer d-flex gap-2 mt-auto">
          <span class="server-skeleton server-skeleton-chip"></span>
          <span class="server-skeleton server-skeleton-chip"></span>
        </span>
      </article>
    </div>
  ))}
</div>
