---
import { SITE } from "../config";
import SectionOrnament from "./SectionOrnament.astro";
import ComparisonCell from "./ComparisonCell.astro";
import { comparisonCategories, plugins } from "../data/comparison";

const categoryIcons: Record<string, string> = {
  general: "fa-circle-info",
  claiming: "fa-map-location-dot",
  ux: "fa-desktop",
  chat: "fa-comments",
  config: "fa-sliders",
  economy: "fa-coins",
  protection: "fa-shield-halved",
  relations: "fa-skull-crossbones",
  admin: "fa-screwdriver-wrench",
};
---
<section class="comparison position-relative" id="comparison" aria-labelledby="comparison-title">
  <div class="container position-relative z-1">
    <h2 class="section-title text-center" id="comparison-title">How KingdomsX compares</h2>
    <SectionOrnament />
    <p class="section-kicker text-center mx-auto">
      Compare KingdomsX side-by-side with other popular Minecraft land claiming plugins to find whether and why it's just the right fit for your server.
    </p>
    <p class="comparison-swipe-hint text-center mx-auto mt-3 mb-0" aria-hidden="true">
      <i class="fa-solid fa-arrows-left-right" aria-hidden="true"></i>
      Swipe inside the table to see other plugin columns
    </p>

    <div class="accordion comparison-accordion mt-5" id="comparison-accordion">
      {comparisonCategories.map((category) => (
        <div class="comparison-panel">
          <button
            class:list={[
              "comparison-panel-header",
              !category.defaultOpen && "collapsed"
            ]}
            type="button"
            data-bs-toggle="collapse"
            data-bs-target={`#panel-body-${category.id}`}
            aria-expanded={category.defaultOpen ? "true" : "false"}
            aria-controls={`panel-body-${category.id}`}
          >
            <span class="comparison-panel-icon">
              <i class={`fa-solid ${categoryIcons[category.id] || "fa-circle"}`} aria-hidden="true"></i>
            </span>
            <span class="comparison-panel-title">{category.label}</span>
            <!--<span class="comparison-panel-count">{category.rows.length} features</span>-->
            <span class="comparison-panel-chevron">
              <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
            </span>
          </button>
          <div
            id={`panel-body-${category.id}`}
            class:list={[
              "collapse",
              category.defaultOpen && "show",
              "comparison-panel-body"
            ]}
            data-bs-parent="#comparison-accordion"
          >
            <div class="table-responsive comparison-shell" role="region" aria-label={`${category.label} comparison`} tabindex="0">
              <table class="table table-hover align-middle text-center mb-0 comparison-table">
                <thead>
                  <tr>
                    <th scope="col" class="comparison-feature-col">Feature</th>
                    {plugins.map((plugin) => (
                      <th scope="col" class:list={[plugin.id === "kingdomsx" && "kingdomsx-column"]} data-plugin={plugin.id}>
                        {plugin.label}
                      </th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {category.rows.map((row) => (
                    <tr class="comparison-row">
                      <th scope="row" class="comparison-feature-col">
                        <div class="feature-title-wrap d-flex align-items-center justify-content-between">
                          <span>{row.feature}</span>
                          {row.hint && (
                            <button
                              class="feature-hint"
                              type="button"
                              data-bs-toggle="tooltip"
                              data-bs-placement="top"
                              data-bs-title={row.hint}
                              aria-label={`What ${row.feature} means`}
                            >
                              <i class="fa-regular fa-circle-question" aria-hidden="true"></i>
                            </button>
                          )}
                        </div>
                      </th>
                      {plugins.map((plugin) => (
                        <ComparisonCell
                          value={row.values[plugin.id]}
                          highlight={plugin.id === "kingdomsx"}
                          data-plugin={plugin.id}
                        />
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      ))}
    </div>

    <p class="comparison-footnote text-center mx-auto mt-5 mb-0">
      Sources:
      <a href="https://factions.support/" target="_blank" rel="noopener noreferrer">FactionsUUID wiki</a>,
      <a href="https://wiki.incredibleplugins.com/lands" target="_blank" rel="noopener noreferrer">Lands wiki</a>,
      <a href="https://github.com/TownyAdvanced/Towny/wiki" target="_blank" rel="noopener noreferrer">Towny wiki</a>,
      and
      <a href="https://docs.griefprevention.com/" target="_blank" rel="noopener noreferrer">GriefPrevention docs</a>.
    </p>
  </div>
</section>
