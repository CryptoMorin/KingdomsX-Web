---
import { SITE } from "../config";
import { siteImages } from "../site-assets";

interface Props {
  homeUrl?: string;
}

const { homeUrl = "" } = Astro.props;
const sectionHref = (id: string) => `${homeUrl}#${id}`;
---
<header class="site-header sticky-top">
  <nav class="navbar navbar-expand-xl" aria-label="Main navigation">
    <div class="container">
      <a class="navbar-brand brand d-inline-flex align-items-center gap-3 mb-0 fw-bold" href={sectionHref("home")} aria-label="KingdomsX home">
        <img src={siteImages.logo} alt="" width="256" height="256" draggable="false" />
        <span>KingdomsX</span>
      </a>
      <button class="navbar-toggler d-inline-grid d-xl-none ms-auto" type="button" data-bs-toggle="offcanvas" data-bs-target="#main-navigation" aria-controls="main-navigation" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="offcanvas-xl offcanvas-end main-navigation flex-xl-grow-1" tabindex="-1" id="main-navigation" aria-labelledby="main-navigation-title">
        <div class="offcanvas-header d-xl-none position-relative z-1 justify-content-between gap-3">
          <h2 class="offcanvas-title brand d-inline-flex align-items-center gap-3 mb-0 fw-bold" id="main-navigation-title">
            <img src={siteImages.logo} alt="" width="256" height="256" draggable="false" />
            <span>KingdomsX</span>
          </h2>
          <button type="button" class="btn-close d-grid" data-bs-dismiss="offcanvas" data-bs-target="#main-navigation" aria-label="Close navigation"></button>
        </div>
        <div class="offcanvas-body position-relative z-1 d-flex flex-column flex-xl-row justify-content-start justify-content-xl-between text-center align-items-xl-center w-100">
          <div class="navbar-nav nav-links flex-xl-grow-1 justify-content-xl-center align-items-stretch align-items-xl-center gap-2 gap-xl-4" aria-label="Page sections">
            <a class="nav-link d-flex d-xl-block align-items-center justify-content-center fw-bold" href={sectionHref("home")}><i class="fa-solid fa-house fa-fw me-2 d-xl-none" aria-hidden="true"></i>Home</a>
            <a class="nav-link d-flex d-xl-block align-items-center justify-content-center fw-bold" href={sectionHref("features")}><i class="fa-solid fa-star fa-fw me-2 d-xl-none" aria-hidden="true"></i>Features</a>
            <a class="nav-link d-flex d-xl-block align-items-center justify-content-center fw-bold" href={sectionHref("preview")}><i class="fa-solid fa-eye fa-fw me-2 d-xl-none" aria-hidden="true"></i>Preview</a>
            <a class="nav-link d-flex d-xl-block align-items-center justify-content-center fw-bold" href={sectionHref("comparison")}><i class="fa-solid fa-scale-balanced fa-fw me-2 d-xl-none" aria-hidden="true"></i>Compare</a>
            <a class="nav-link d-flex d-xl-block align-items-center justify-content-center fw-bold" href={sectionHref("gallery")}><i class="fa-solid fa-images fa-fw me-2 d-xl-none" aria-hidden="true"></i>Gallery</a>
            <a class="nav-link d-flex d-xl-block align-items-center justify-content-center fw-bold" href={sectionHref("addons")}><i class="fa-solid fa-puzzle-piece fa-fw me-2 d-xl-none" aria-hidden="true"></i>Addons</a>
          </div>
          <div class="header-actions position-relative flex-xl-shrink-0 mt-3 mt-xl-0 ms-xl-5">
            <div class="header-action-buttons d-flex flex-column flex-xl-row align-items-stretch align-items-xl-center justify-content-center justify-content-xl-end gap-2 w-100 top-0 end-0 bottom-0 start-0">
              <a class="btn btn-kingdom btn-discord d-inline-flex align-items-center justify-content-center gap-2 gap-xl-0 fw-bold py-2 px-3 overflow-hidden flex-xl-shrink-0" href={SITE.discord} target="_blank" rel="noopener noreferrer" aria-label="Join Discord">
                <span class="header-action-icon d-inline-flex align-items-center justify-content-center flex-shrink-0" aria-hidden="true"><i class="fa-brands fa-discord"></i></span>
                <span class="header-action-label d-xl-inline-grid overflow-hidden text-nowrap"><span>Discord</span></span>
              </a>
              <a class="btn btn-kingdom btn-wiki d-inline-flex align-items-center justify-content-center gap-2 gap-xl-0 fw-bold py-2 px-3 overflow-hidden flex-xl-shrink-0" href={SITE.wiki} target="_blank" rel="noopener noreferrer" aria-label="Read the Wiki">
                <span class="header-action-icon d-inline-flex align-items-center justify-content-center flex-shrink-0" aria-hidden="true"><i class="fa-solid fa-book-open"></i></span>
                <span class="header-action-label d-xl-inline-grid overflow-hidden text-nowrap"><span>Wiki</span></span>
              </a>
              <a class="btn btn-kingdom btn-download d-inline-flex align-items-center justify-content-center gap-2 gap-xl-0 fw-bold py-2 px-3 overflow-hidden flex-xl-shrink-0" href={SITE.download} target="_blank" rel="noopener noreferrer" aria-label="Download KingdomsX">
                <span class="header-action-icon d-inline-flex align-items-center justify-content-center flex-shrink-0" aria-hidden="true"><i class="fa-solid fa-download"></i></span>
                <span class="header-action-label d-xl-inline-grid overflow-hidden text-nowrap"><span>Download</span></span>
              </a>
            </div>
            <div class="header-action-sizer d-none d-xl-flex align-items-center justify-content-end gap-2 invisible pe-none" aria-hidden="true">
              <span class="btn btn-kingdom btn-discord d-inline-flex align-items-center justify-content-center fw-bold py-2 px-3 flex-xl-shrink-0">
                <span class="header-action-icon d-inline-flex align-items-center justify-content-center flex-shrink-0"><i class="fa-brands fa-discord"></i></span>
              </span>
              <span class="btn btn-kingdom btn-wiki d-inline-flex align-items-center justify-content-center fw-bold py-2 px-3 flex-xl-shrink-0">
                <span class="header-action-icon d-inline-flex align-items-center justify-content-center flex-shrink-0"><i class="fa-solid fa-book-open"></i></span>
              </span>
              <span class="btn btn-kingdom btn-download d-inline-flex align-items-center justify-content-center fw-bold py-2 px-3 flex-xl-shrink-0">
                <span class="header-action-icon d-inline-flex align-items-center justify-content-center flex-shrink-0"><i class="fa-solid fa-download"></i></span>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </nav>
</header>
