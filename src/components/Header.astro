---
import { SITE } from "../config";
---
<header class="site-header sticky-top">
  <nav class="navbar navbar-expand-lg" aria-label="Main navigation">
    <div class="container">
      <a class="navbar-brand brand d-inline-flex align-items-center gap-3 mb-0" href="#top" aria-label="KingdomsX home">
        <img src={`${SITE.assets}/images/logo.webp`} alt="" width="256" height="256" draggable="false" />
        <span>KingdomsX</span>
      </a>
      <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#main-navigation" aria-controls="main-navigation" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse text-center" id="main-navigation">
        <div class="navbar-nav nav-links mx-lg-auto align-items-center gap-lg-4 pt-3 pt-lg-0" aria-label="Page sections">
          <a class="nav-link" href="#features">Features</a>
          <a class="nav-link" href="#preview">Preview</a>
          <a class="nav-link" href="#addons">Addons</a>
          <a class="nav-link" href={SITE.download} target="_blank" rel="noopener noreferrer">Download</a>
        </div>
        <div class="header-actions d-flex flex-column flex-sm-row align-items-center justify-content-center gap-2 mt-3 mt-lg-0 ms-lg-4">
          <a class="btn btn-kingdom btn-discord d-inline-flex align-items-center justify-content-center gap-2 fw-bold py-2 px-3" href={SITE.discord} target="_blank" rel="noopener noreferrer">
            <i class="fa-brands fa-discord" aria-hidden="true"></i> Discord
          </a>
          <a class="btn btn-kingdom d-inline-flex align-items-center justify-content-center gap-2 fw-bold py-2 px-3" href={SITE.wiki} target="_blank" rel="noopener noreferrer">
            <i class="fa-solid fa-book-open" aria-hidden="true"></i> Wiki
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>
