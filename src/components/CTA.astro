---
import { SITE } from "../config";
import { siteImages } from "../site-assets";
import SectionOrnament from "./SectionOrnament.astro";
---
<section class="cta position-relative" aria-labelledby="cta-title">
  <div class="container position-relative z-1">
    <div class="cta-panel position-relative">
      <div class="d-flex flex-column align-items-center position-relative z-1">
        <h2 class="text-center mb-0" id="cta-title">Ready?</h2>
        <SectionOrnament />
        <p class="text-center mt-3 mb-0">Download the plugin, place it in your <code>plugins</code> folder, and restart the server. It's that simple, no dependencies needed! Supports all the older and latest Minecraft versions too.</p>
        <div class="d-flex flex-wrap gap-3 mt-4 justify-content-center">
          <a class="btn btn-site btn-site-primary d-inline-flex align-items-center justify-content-center gap-2 fw-bold" href={SITE.spigot} target="_blank" rel="noopener noreferrer">
            <img class="icon icon-img" src={siteImages.spigot} alt="" width="24" height="24" aria-hidden="true" draggable="false" />
            Get on SpigotMC
          </a>
          <a class="btn btn-site btn-modrinth d-inline-flex align-items-center justify-content-center gap-2 fw-bold" href={SITE.modrinth} target="_blank" rel="noopener noreferrer">
            <img class="icon icon-img" src={siteImages.modrinth} alt="" width="250" height="251" aria-hidden="true" draggable="false" />
            View on Modrinth
          </a>
          <a class="btn btn-site btn-discord d-inline-flex align-items-center justify-content-center gap-2 fw-bold" href={SITE.discord} target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-discord"></i> Join Discord</a>
          <a class="btn btn-site d-inline-flex align-items-center justify-content-center gap-2 fw-bold" href={SITE.wiki} target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-book-open" aria-hidden="true"></i> Read the Wiki</a>
        </div>
      </div>
    </div>
  </div>
</section>
