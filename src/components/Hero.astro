---
import { SITE } from "../config";
import { siteImages } from "../site-assets";
---
<section class="hero d-flex flex-column position-relative overflow-hidden" aria-labelledby="hero-title">
  <div class="hero-particles position-absolute top-0 bottom-0 start-50 z-1 pe-none translate-middle-x" id="hero-particles" aria-hidden="true"></div>
  <div class="hero-grid container flex-grow-1 d-flex align-items-center">
    <div class="hero-copy position-relative z-2 w-100">
      <h1 class="mb-0" id="hero-title"><span>Battles for might,</span><span>land and glory.</span></h1>
      <p class="lead">KingdomsX is a plugin similar to Factions which provides more advanced core features and introduces new mechanics such as turrets, structures, and invasions to make the game more fun.</p>
      <div class="d-flex flex-wrap gap-3 mt-4" aria-label="Primary plugin links">
        <a class="btn btn-kingdom btn-kingdom-primary d-inline-flex align-items-center justify-content-center gap-2 fw-bold" href={SITE.spigot} target="_blank" rel="noopener noreferrer">
          <img class="icon icon-img" src={siteImages.spigot} alt="" width="24" height="24" aria-hidden="true" draggable="false" />
          Get on SpigotMC
        </a>
        <a
          class="btn btn-kingdom btn-dev-builds d-inline-flex align-items-center justify-content-center gap-2 fw-bold"
          href={SITE.discord}
          target="_blank"
          rel="noopener noreferrer"
          data-discord-deep-link={SITE.discordDevBuilds}
          data-discord-fallback={SITE.discord}
        >
          <i class="fa-solid fa-hammer icon" aria-hidden="true"></i>
          Get Dev Builds
        </a>
      </div>
    </div>
  </div>
  <div class="divider position-absolute start-0 end-0 bottom-0 overflow-hidden">
    <a class="divider-caret position-absolute top-0 start-50 translate-middle-x d-inline-block" href="#features" aria-label="Scroll to features"></a>
  </div>
</section>
