---
import { SITE } from "../config";

interface Props {
  status: string;
  title: string;
  message: string;
}

const { status, title, message } = Astro.props;
const homeUrl = SITE.url || "/";
---
<section class="error-page d-flex align-items-center justify-content-center text-center" aria-labelledby={`error-${status}-title`}>
  <div class="container position-relative z-1">
    <div class="error-content d-flex flex-column align-items-center mx-auto">
      <p class="error-code mb-2 fw-bold" aria-hidden="true">{status}</p>
      <h1 class="mw-100 mb-0" id={`error-${status}-title`}>{title}</h1>
      <p class="error-message mx-auto mb-0">{message}</p>
      <div class="error-actions d-flex flex-wrap justify-content-center gap-3 mt-4">
        <a class="btn btn-site btn-site-primary d-inline-flex align-items-center justify-content-center gap-2 fw-bold" href={homeUrl}>
          <i class="fa-solid fa-house-chimney" aria-hidden="true"></i>
          Return Home
        </a>
        <a class="btn btn-site d-inline-flex align-items-center justify-content-center gap-2 fw-bold" href={`${SITE.wiki}/search`} target="_blank" rel="noopener noreferrer">
          <i class="fa-solid fa-book-open" aria-hidden="true"></i>
          Search the Wiki
        </a>
      </div>
    </div>
  </div>
</section>
