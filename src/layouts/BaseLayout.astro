---
import { SITE } from "../config";
import heroBanner from "../assets/images/cta-castle-banner.webp";
import { Font } from "astro:assets";
import "bootstrap/dist/css/bootstrap.min.css";
import "@fortawesome/fontawesome-free/css/all.min.css";
import "../assets/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  canonicalUrl?: string;
  robots?: string;
  preloadHeroImage?: boolean;
  includeStructuredData?: boolean;
}

const defaultTitle = "KingdomsX | Battles for might, land and glory";
const defaultDescription = "KingdomsX is a plugin similar to Factions which provides more advanced core features and introduces new mechanics such as turrets, structures, and invasions to make the game more fun.";
const {
  title = defaultTitle,
  description = defaultDescription,
  canonicalPath = "/",
  canonicalUrl: canonicalUrlOverride = "",
  robots = "index, follow, max-image-preview:large",
  preloadHeroImage = true,
  includeStructuredData = true
} = Astro.props;
const normalizedCanonicalPath = canonicalPath === "/" ? "/" : `/${canonicalPath.replace(/^\/+|\/+$/g, "")}`;
const siteUrl = SITE.url || "";
const shouldIncludeStructuredData = includeStructuredData && siteUrl;
const canonicalUrl = canonicalUrlOverride || (siteUrl ? `${siteUrl}${normalizedCanonicalPath}` : normalizedCanonicalPath);
const publicUrl = (path: string) => {
  const normalizedPath = `/${path.replace(/^\/+/, "")}`;
  return siteUrl ? `${siteUrl}${normalizedPath}` : normalizedPath;
};
const heroBannerUrl = typeof heroBanner === "string" ? heroBanner : heroBanner.src;
const faviconPngUrl = publicUrl("favicon-96x96.png");
const faviconSvgUrl = publicUrl("favicon.svg");
const faviconIcoUrl = publicUrl("favicon.ico");
const appleTouchIconUrl = publicUrl("apple-touch-icon.png");
const manifestUrl = publicUrl("site.webmanifest");
const manifestIconUrl = publicUrl("web-app-manifest-512x512.png");
const ogImageUrl = publicUrl("og-img.png");
---
<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="Kingdoms, KingdomsX, Minecraft kingdoms plugin, Minecraft factions plugin, Spigot plugin, land claiming plugin, Minecraft nations, Minecraft diplomacy, Minecraft server plugin, PvP plugin" />
    <meta name="author" content="Crypto Morin" />
    <meta name="application-name" content="KingdomsX" />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    <meta name="theme-color" content="#071019" />
    <meta name="color-scheme" content="dark" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <link rel="icon" type="image/png" href={faviconPngUrl} sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href={faviconSvgUrl} />
    <link rel="shortcut icon" href={faviconIcoUrl} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleTouchIconUrl} />
    <meta name="apple-mobile-web-app-title" content="KingdomsX" />
    <meta name="msapplication-TileColor" content="#071019" />
    <link rel="manifest" href={manifestUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="KingdomsX" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="KingdomsX plugin banner" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="KingdomsX plugin banner" />
    {preloadHeroImage && <link rel="preload" as="image" href={heroBannerUrl} fetchpriority="high" />}
    <Font cssVariable="--font-lora" preload />
    {shouldIncludeStructuredData && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": `${siteUrl}/#website`,
          "name": SITE.name,
          "url": `${siteUrl}/`,
          "description": description,
          "inLanguage": "en",
          "publisher": { "@id": `${siteUrl}/#organization` }
        },
        {
          "@type": "Organization",
          "@id": `${siteUrl}/#organization`,
          "name": SITE.name,
          "url": `${siteUrl}/`,
          "logo": {
            "@type": "ImageObject",
            "url": manifestIconUrl,
            "width": 512,
            "height": 512
          },
          "sameAs": [SITE.github, SITE.spigot, SITE.modrinth, SITE.discord, SITE.wiki]
        },
        {
          "@type": "SoftwareApplication",
          "@id": `${siteUrl}/#software`,
          "name": SITE.name,
          "applicationCategory": "GameApplication",
          "operatingSystem": "Minecraft server",
          "url": `${siteUrl}/`,
          "downloadUrl": SITE.spigot,
          "softwareHelp": SITE.wiki,
          "image": ogImageUrl,
          "description": description,
          "author": { "@type": "Person", "name": "Crypto Morin", "url": SITE.author },
          "publisher": { "@id": `${siteUrl}/#organization` },
          "offers": { "@type": "Offer", "url": SITE.spigot, "availability": "https://schema.org/InStock" }
        }
      ]
    })} />)}
  </head>
  <body>
    <slot />
    <script>
      import "../assets/scripts/site.js";
    </script>
  </body>
</html>
