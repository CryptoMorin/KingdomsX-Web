---
import { SITE } from "../config";

const title = "KingdomsX | Battles for might, land and glory";
const description = "KingdomsX is a plugin similar to Factions which provides more advanced core features and introduces new mechanics such as turrets, structures, and invasions to make the game more fun.";
---
<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="Kingdoms, KingdomsX, Minecraft kingdoms plugin, Minecraft factions plugin, Spigot plugin, land claiming plugin, Minecraft nations, Minecraft diplomacy, Minecraft server plugin, PvP plugin" />
    <meta name="author" content="Crypto Morin" />
    <meta name="application-name" content="KingdomsX" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="googlebot" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#071019" />
    <meta name="color-scheme" content="dark" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="canonical" href={`${SITE.url}/`} />
    <link rel="alternate" hreflang="en" href={`${SITE.url}/`} />
    <link rel="alternate" hreflang="x-default" href={`${SITE.url}/`} />
    <link rel="icon" type="image/png" href={`${SITE.assets}/images/seo/favicon-96x96.png`} sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href={`${SITE.assets}/images/seo/favicon.svg`} />
    <link rel="shortcut icon" href={`${SITE.assets}/images/seo/favicon.ico`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${SITE.assets}/images/seo/apple-touch-icon.png`} />
    <meta name="apple-mobile-web-app-title" content="KingdomsX" />
    <meta name="msapplication-TileColor" content="#071019" />
    <link rel="manifest" href={`${SITE.assets}/images/seo/site.webmanifest`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="KingdomsX" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${SITE.url}/`} />
    <meta property="og:image" content={`${SITE.assets}/images/seo/og-img.png`} />
    <meta property="og:image:secure_url" content={`${SITE.assets}/images/seo/og-img.png`} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="KingdomsX plugin banner" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE.assets}/images/seo/og-img.png`} />
    <meta name="twitter:image:alt" content="KingdomsX plugin banner" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="image" href={`${SITE.assets}/images/cta-castle-banner.webp`} fetchpriority="high" />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" integrity="sha256-2FMn2Zx6PuH5tdBQDRNwrOo60ts5wWPC9R8jK67b3t4=" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@7.2.0/css/all.min.css" integrity="sha256-MVopmdyC2tYTiJ8wlktf0uh0v4NgT+vNdyVFepi7Q0c=" crossorigin="anonymous" />
    <link rel="stylesheet" href={`${SITE.assets}/css/style.css?v=${SITE.assetVersion}`} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": `${SITE.url}/#website`,
          "name": SITE.name,
          "url": `${SITE.url}/`,
          "description": description,
          "inLanguage": "en",
          "publisher": { "@id": `${SITE.url}/#organization` }
        },
        {
          "@type": "Organization",
          "@id": `${SITE.url}/#organization`,
          "name": SITE.name,
          "url": `${SITE.url}/`,
          "logo": {
            "@type": "ImageObject",
            "url": `${SITE.assets}/images/seo/web-app-manifest-512x512.png`,
            "width": 512,
            "height": 512
          },
          "sameAs": [SITE.github, SITE.spigot, SITE.modrinth, SITE.discord, SITE.wiki]
        },
        {
          "@type": "SoftwareApplication",
          "@id": `${SITE.url}/#software`,
          "name": SITE.name,
          "applicationCategory": "GameApplication",
          "operatingSystem": "Minecraft server",
          "url": `${SITE.url}/`,
          "downloadUrl": SITE.spigot,
          "softwareHelp": SITE.wiki,
          "image": `${SITE.assets}/images/seo/og-img.png`,
          "description": description,
          "author": { "@type": "Person", "name": "Crypto Morin", "url": SITE.author },
          "publisher": { "@id": `${SITE.url}/#organization` },
          "offers": { "@type": "Offer", "url": SITE.spigot, "availability": "https://schema.org/InStock" }
        }
      ]
    })} />
  </head>
  <body>
    <slot />
    <script src={`${SITE.assets}/js/preview.js?v=${SITE.assetVersion}`}></script>
    <script src={`${SITE.assets}/js/dev-builds-link.js?v=${SITE.assetVersion}`}></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha256-5P1JGBOIxI7FBAvT/mb1fCnI5n/NhQKzNUuW7Hq0fMc=" crossorigin="anonymous"></script>
  </body>
</html>
