{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "kingdomsx-web",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-06-19",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": true
  },
  "observability": {
    "enabled": true
  }
}
